# ─── DEPLOY CHECKLIST ────────────────────────────────────────────────────────
# Antes de hacer build para producción, actualiza VITE_API_URL con la URL real
# del backend desplegado. Es el único cambio de frontend necesario para prod.
# También agrega CORS_ORIGINS en el .env del backend con el dominio del frontend.
# ─────────────────────────────────────────────────────────────────────────────
VITE_API_URL=https://api.yourdomain.com
